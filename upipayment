# Function to calculate the area of a rectangle
def calculate_area(length, width):
    return length * width

# Get user input and convert to floats
try:
    user_length = float(input("Enter the length: "))
    user_width = float(input("Enter the width: "))
    
    # Check if numbers are positive
    if user_length > 0 and user_width > 0:
        area = calculate_area(user_length, user_width)
        print(f"The calculated area is: {area}")
    else:
        print("Please enter positive numbers.")
except ValueError:
    print("Invalid input! Please enter numeric values.")
